# Memory init file – tiny test case (SIZE=2, LOOPS=1)
#
# Format: <hex_byte_address> <hex_32bit_value>
# All values are 32-bit integers stored little-endian.
#
# Layout for SIZE=2, LOOPS=1:
#   addrC = 0x000400   (2x2 = 4 words = 16 bytes)
#   addrA = 0x000410   (immediately after C)
#   addrB = 0x000420   (immediately after A)
#
# Matrix A = [[1, 2], [3, 4]]
00000410 00000001
00000414 00000002
00000418 00000003
0000041C 00000004
#
# Matrix B = [[5, 6], [7, 8]]
00000420 00000005
00000424 00000006
00000428 00000007
0000042C 00000008
#
# Expected C = A*B = [[1*5+2*7, 1*6+2*8], [3*5+4*7, 3*6+4*8]]
#                  = [[19, 22], [43, 50]]
